# ==============================================================================
# UtilityMate - Environment Configuration Example
# ==============================================================================

# [REQUIRED] Security - JSON Web Token signing key. 
# Generate a strong one using: openssl rand -hex 32
SECRET_KEY=change_this_to_a_long_random_string_for_production

# [OPTIONAL] Database Configuration
# Defaults to sqlite:////app/data/utilitymate.db in the container
# For external Postgres: postgresql://user:password@hostname:5432/dbname
# DATABASE_URL=postgresql://utilitymate_user:utilitymate_pass@db:5432/utilitymate

# [OPTIONAL] CORS Configuration
# Comma-separated list of allowed origins for the API
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,https://utilitymate.adandu.ro

# [OPTIONAL] File Storage
# Where to store uploaded invoice PDFs inside the container
UPLOAD_DIR=/app/data/invoices

# [OPTIONAL] App Version
# Usually read from the VERSION file, but can be overridden here
# APP_VERSION=1.1.3

# [DOCKER SPECIFIC] 
# These are used by docker-compose.yml to initialize the Postgres container (if used)
POSTGRES_USER=utilitymate_user
POSTGRES_PASSWORD=utilitymate_pass
POSTGRES_DB=utilitymate
